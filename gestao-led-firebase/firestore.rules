rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ATENCAO (PROTOTIPO): regras abertas para desenvolvimento.
    // Antes de usar em producao com dados reais, ative o Firebase
    // Authentication e troque a condicao para: request.auth != null
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
